{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "UAgent",
  "version": "0.0.1",
  "identifier": "com.uagent.desktop",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm web:dev",
    "beforeBuildCommand": "pnpm web:build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "UAgent",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
